# ATL4S environment variables

# ROS 2 settings — applies to all services
ROS_DOMAIN_ID=42

# MAVROS connection
# Format: udp://[bind_host][:bind_port]@[remote_host][:remote_port]
# udp://:14550@  → bind on 0.0.0.0:14550, no remote (accept any sender, learn reply addr from first packet).
# udp://@:14550  → WRONG: binds on default port 14555 and treats :14550 as the remote.
FCU_URL=udp://:14550@
GCS_URL=

# SITL settings
SITL_HOME_LAT=37.6213
SITL_HOME_LON=-122.3790
SITL_HOME_ALT=5
SITL_HOME_HEADING=0

# MAVProxy `--out` target. udp: is bidirectional (MAVROS commands round-trip).
# udpout: is telemetry-only — use it only if downstream must never send back.
MAVPROXY_OUT=udp:127.0.0.1:14550

# Foxglove WebSocket bridge
FOXGLOVE_PORT=8765

# Commander — normalized battery percentage (0..1) at or below which RTL fires.
BATTERY_LOW_THRESHOLD=0.20

# dashboard — single operator UI on TCP 8089 with HTTP Basic.
# Set BOTH user + pass or NEITHER. Service refuses to start on half-config.
# Empty disables auth (only safe behind a closed firewall).
DASHBOARD_BIND=0.0.0.0
DASHBOARD_PORT=8089
BAG_WEB_USER=
BAG_WEB_PASS=

# rosbag-manager — HTTP API for bag-plane operations. Loopback by default;
# the dashboard fronts it with HTTP Basic. Default record topic list applies
# when POST /api/record/start omits `topics`.
ROSBAG_MANAGER_BIND=127.0.0.1
ROSBAG_MANAGER_PORT=8086
ROSBAG_MANAGER_STABLE_SECONDS=15
ROSBAG_MANAGER_POLL_SECONDS=10
RECORD_TOPICS=/mavros/state /mavros/battery /mavros/global_position/global /mavros/imu/data /camera/image /camera/camera_info

# GCP integration
GCP_PROJECT_ID=
GCS_BUCKET=atl4s-rosbags
PUBSUB_TOPIC=
