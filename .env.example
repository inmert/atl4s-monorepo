# ATL4S environment variables

# ROS 2 settings — applies to all services
ROS_DOMAIN_ID=42
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp

# MAVROS connection
# For SITL development: udp://@:14550 (listen on all interfaces, port 14550)
# For drone via Orin: udp://@:14550 (same — Orin sends to this VM's IP:14550)
FCU_URL=udp://@:14550
GCS_URL=

# SITL settings
SITL_HOME_LAT=37.6213
SITL_HOME_LON=-122.3790
SITL_HOME_ALT=5
SITL_HOME_HEADING=0

# GCP integration
GCP_PROJECT_ID=
GCS_BUCKET=atl4s-rosbags
PUBSUB_TOPIC=
