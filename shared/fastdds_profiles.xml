<?xml version="1.0" encoding="UTF-8" ?>
<!--
  Forces FastDDS to use UDPv4 only.

  Default behavior prefers the shared-memory transport when both endpoints
  look local. Our containers run with network_mode: host but separate
  /dev/shm, so SHM-routed data is silently dropped while DDS discovery
  (UDP multicast) still works. Loaded via FASTRTPS_DEFAULT_PROFILES_FILE.
-->
<profiles xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">

  <transport_descriptors>
    <transport_descriptor>
      <transport_id>udp_transport</transport_id>
      <type>UDPv4</type>
    </transport_descriptor>
  </transport_descriptors>

  <participant profile_name="participant_default" is_default_profile="true">
    <rtps>
      <userTransports>
        <transport_id>udp_transport</transport_id>
      </userTransports>
      <useBuiltinTransports>false</useBuiltinTransports>
    </rtps>
  </participant>

</profiles>
